// Persistent agent registry — links public agentId / embedToken to the
// underlying sandbox-host microVM. Source of truth for agent ownership and
// embedToken auth. The microVM itself lives in sandbox-host (not Mongo);
// expiresAt mirrors the sandbox auto-destroy TTL.
model Agent {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String    @db.ObjectId
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sandboxId   String
  agentUrl    String
  template    String
  embedToken  String    @unique
  name        String?
  status      String    @default("running")
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  // Runtime metadata snapshot at create — drives messageAgent dispatch
  // (sse vs acp). Defaults preserve back-compat with chat-* templates.
  protocol     String? @default("sse")
  port         Int?    @default(3000)
  unit         String? @default("chat-runtime")
  messagePath  String? @default("/message")
  // ACP only — populated during eager handshake at startAgent. Reused
  // across messages so we don't re-initialize per call.
  // - acpTransportSessionId: emitted by Goose serve in the initialize
  //   response header `Acp-Session-Id`. Required on every subsequent call.
  // - acpSessionId: returned by session/new — identifies the agent session.
  acpTransportSessionId String?
  acpSessionId          String?

  // URL pública del escritorio noVNC (templates desktop-*). Se popula al
  // exponer :6080 en createAgent; null para el resto.
  desktopUrl String?

  // URL pública de la terminal ttyd→tmux con basic-auth inline (computer-ghosty).
  // Se popula al exponer :7681 en createAgent; null para el resto.
  terminalUrl String?

  // WhatsApp link state (cache from openclaw runtime). Shape:
  //   { status: "disconnected"|"qr_pending"|"pairing"|"connected",
  //     phoneNumber?: string, lastSyncAt?: string, linkedAt?: string }
  // Source of truth is the runtime gateway at agentUrl:port/whatsapp/*;
  // this is mirrored on every status/link/unlink call so the dash can show
  // last-known state without a roundtrip.
  whatsapp Json?

  // FleetAgent membership: when set, this Agent is an EPHEMERAL worker spawned by
  // a FleetAgent (not a standalone always-on agent). The fleet manager picks/
  // spawns/suspends these by RAM budget. null = standalone agent (legacy 1:1).
  fleetAgentId  String?   @db.ObjectId
  // Last time a message was dispatched to this worker — drives the idle reaper
  // (suspend after FleetAgent.idleSuspendMin of silence). Null until first message.
  lastMessageAt DateTime?
  // Which box (sandbox-host base URL) this VM lives on. Null = the default
  // SANDBOX_HOST_URL. Multi-box seam: dispatch/suspend resolve the host from here.
  host          String?

  @@index([ownerId])
  @@index([fleetAgentId])
}

// A FleetAgent is the always-on SURFACE (Baileys/WhatsApp) for one owner that
// routes inbound group messages to a fleet of ephemeral worker Agents. Workers
// are spawned on demand, multiplex conversations by sessionId=groupId, scale out
// when full (RAM-gated), and suspend when idle (warm window). The conversation
// branding/personality is injected per spawn from `persona`.
model FleetAgent {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId       String   @db.ObjectId
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String?
  // Bearer the Baileys surface presents on POST /api/v2/fleet-agents/:id/message.
  token         String   @unique
  // VM template to spawn. Default is "claude-worker" (Claude Agent SDK + OAuth,
  // native .jsonl transcript resume); interchangeable with "ghosty-gc".
  workerTemplate String  @default("claude-worker")
  // Per-spawn branding/personality. Shape:
  //   { name?: string, env?: Record<string,string>,
  //     seedFiles?: Array<{ name: string; contentBase64: string }> }
  // Passed straight to createAgent so every VM boots branded.
  persona       Json?
  // Which vault secret holds the Claude OAuth for this channel's workers. Lets
  // different channels use different Max accounts (reselling). null = default
  // "CLAUDE_CODE_OAUTH_TOKEN". spawnVm resolves it → injects into the worker.
  oauthSecretName String?
  // Scaling knobs. Hierarchy: VM (sandboxId) hosts N workers; worker = 1
  // conversation = 1 sessionId. When a VM hits maxWorkersPerVm, spawn another VM.
  maxWorkersPerVm Int  @default(2)    // conversations (workers) per VM (512MB ≈ 2)
  vmMemMb         Int  @default(512)  // RAM gate: free >= this to spawn a VM
  maxVms          Int  @default(10)   // hard cap on fleet agent's own VMs
  idleSuspendMin     Int  @default(5)    // suspend a worker after N idle min (memory backed up first)
  // Destroy a suspended worker after N idle min to reclaim host disk. Its
  // conversation memory is externalized to storage at suspend, so the next
  // message restores it onto a fresh VM. Must be > idleSuspendMin. Kept generous
  // so suspended VMs stay resumable (~700-950ms snapshot resume vs ~12s cold boot
  // + restore-from-S3); restore round-trip is verified, so destroy is only deferred.
  destroyIdleMin     Int  @default(45)
  // WABA (WhatsApp Business / Meta) channel config. Formmy is the gateway: it
  // owns the Meta number and FORWARDS each inbound message to this fleet agent, then
  // expects us to POST the reply back to Formmy's /send. Shape:
  //   { formmySecret: string,
  //     orgs: { [integrationId]: { denikApiKey: string, phoneNumberId: string } } }
  // formmySecret = bearer Formmy presents on POST /waba/message AND the bearer we
  // present back to Formmy. orgs maps a Formmy integration (per tenant org) to its
  // Denik MCP key (per-turn worker scope) + Meta phone_number_id (for the reply).
  wabaConfig    Json?
  // Baileys pairing state mirror (same shape as Agent.whatsapp).
  baileys       Json?
  // Persisted Baileys auth (creds + signal keys) so the socket survives app
  // redeploys/restarts WITHOUT re-scanning the QR. Written on every creds/keys
  // update; read at boot rehydration. BufferJSON-serialized.
  authCreds     Json?
  authKeys      Json?
  // ANTI-SPAM allowlist: the fleet agent only answers in these group jids. Empty = OFF
  // everywhere (safe default — never auto-replies in all the owner's groups).
  enabledGroups String[] @default([])
  // The fleet agent's MAIN group jid — elevated privileges (cross-group send, invite
  // link, admin tools). Other enabled groups are restricted to their own
  // conversation. null = no main group. Mirrors nanoclaw's isMain.
  mainGroupJid  String?
  // Per-group MCP key map { [groupJid]: DENIK_API_KEY }. Set at group creation
  // (createFleetAgentGroup); routeMessage injects the group's key per message so
  // one shared agent (e.g. denik's "Nik") is scoped to each group's org. Tenant
  // isolation is enforced by the downstream MCP auth, not by trusting the agent.
  groupKeys     Json?
  // The agent's MENU of MCP servers it can offer (config-driven, nanoclaw parity).
  // Array of McpCatalogEntry (see fleetAgentOperations.ts): { name, label?,
  // transport, command?, args?, url?, env?, builtin? }. Seeded on createFleetAgent
  // with the builtins (easybits/wa/denik). The owner (UI) or the agent (main
  // group) can add/remove custom entries (brightdata, kommo, supabase, http…).
  mcpCatalog    Json?
  // Per-group MCP selection + env overrides:
  //   { [groupJid]: { mcpServers?: string[], env?: Record<string,string> } }
  // mcpServers = which catalog entries (by name) are enabled for THIS group;
  // absent = the catalog default set. env = per-group overrides (tenant keys)
  // merged over the catalog entry's static env at resolution time. routeMessage
  // resolves this into the per-turn `mcpServers` map sent to the worker. Kept
  // separate from groupKeys (denik) so the existing per-message denik path stays.
  groupConfigs  Json?
  // Loop-prevention strategy (surface layer, nanoclaw pattern):
  //  - hasOwnNumber=true  → dedicated WhatsApp line; the bot's own output is the
  //    only fromMe → skip fromMe. Owner can't self-test; replies to others only.
  //  - hasOwnNumber=false → personal/shared number (owner uses it too); fromMe is
  //    ambiguous, so the bot tags replies with "assistantName:" and skips only
  //    those → the owner's own messages DO get answered (good for testing).
  hasOwnNumber  Boolean  @default(false)
  assistantName String?  // prefix stamped on replies when !hasOwnNumber (default "Asistente")
  // Groups DISCOVERED from inbound messages (jid → subject), independent of the
  // allowlist. Lets the UI surface a group to enable as soon as it has activity,
  // even before WhatsApp's metadata sync lists it. Merged with groupFetchAll.
  seenGroups    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  routes        FleetAgentRoute[]

  @@index([ownerId])
}

// Sticky mapping: a conversation (WhatsApp group/jid) → the worker Agent that
// serves it. Sticky so in-VM memory (preserved across suspend/resume) stays
// coherent. unique(fleetAgentId, groupId).
model FleetAgentRoute {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  fleetAgentId  String     @db.ObjectId
  fleetAgent    FleetAgent @relation(fields: [fleetAgentId], references: [id], onDelete: Cascade)
  groupId       String   // WhatsApp group jid / conversation key (human-readable)
  // Stable UUID handed to the worker as sessionId — Claude CLI --resume requires
  // UUID format, and it keys the per-conversation .jsonl transcript. groupId is
  // for routing; sessionUuid is the worker's resume handle.
  sessionUuid   String
  // The worker Agent.id currently serving this conversation. NULLABLE: when the
  // idle reaper DESTROYS the VM, the route is kept (it's the handle to the
  // externalized memory blob, keyed by sessionUuid) but agentId is cleared and
  // detachedAt stamped. The next message restores the blob onto a fresh VM and
  // re-points agentId. Null + detachedAt = "cold but resumable".
  agentId       String?  @db.ObjectId
  detachedAt    DateTime?
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  @@unique([fleetAgentId, groupId])
  @@index([agentId])
}

// Durable conversation log — SOURCE OF TRUTH for messages, independent of the
// worker. The Agent SDK's own .jsonl transcript (on the worker volume) drives
// native resume + auto-compact; this table is the portable record (audit,
// funnel, stateless-replay fallback). One row per inbound/outbound turn.
model FleetAgentMessage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  fleetAgentId String   @db.ObjectId
  groupId      String
  role         String   // "user" | "agent"
  sender       String?  // WhatsApp sender (for "user" rows)
  senderName   String?  // nombre de perfil del contacto (WABA: contacts[].profile.name)
  text         String
  createdAt    DateTime @default(now())

  @@index([fleetAgentId, groupId])
  // Inbox: prefix-scan por número (groupId startsWith "waba:<int>:") ordenado por recencia.
  @@index([fleetAgentId, groupId, createdAt])
}

// Local registry row for a sandbox we track in Mongo. ONE model, keyed by the
// host's stable `sandboxId` — same id whether ephemeral or permanent (Fly-style).
// Today a row exists ONLY for PERMANENT (billed always-on) sandboxes; ephemeral
// ones stay host-only. Forward-compatible: to track all sandboxes later, just
// start writing rows for ephemeral ones too (set persistent=false) — no migration.
// `persistent`/`tier`/`cpuMode`/`stripeSubItemId` are fields; "permanent" = the flag.
model Sandbox {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId         String   @db.ObjectId
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sandboxId       String   @unique // host VM id — the single handle (1 sandbox = 1 row)
  persistent      Boolean  @default(true)
  tier            String   // catalog key: "nano".."performance-4x"
  template        String?  // host template (e.g. "ghostyclaw"). Gates the admin
                           // passthrough (pairing/CLAUDE.md) to flagship agents.
  cpuMode         String   @default("shared") // "shared" | "reserved"
  diskAddonsGB    Int      @default(0)        // stackable 100GB NVMe units * 100
  name            String?
  status          String   @default("provisioning") // provisioning|running|suspended|error|lost|destroyed
  // Single Stripe subscription item per permanent sandbox (tier + disk combined).
  stripeSubItemId String?
  // adminToken: Bearer for the box's in-VM admin API (:8787), persisted at
  // create when a managed-runtime template (ghostyclaw) is provisioned with env.
  // Used by the sandbox admin passthrough (/api/v2/sandbox/:id/admin) for
  // WhatsApp pairing + CLAUDE.md CRUD. Parallel to Agent.embedToken.
  adminToken      String?
  // runtimeStatus: managed-runtime readiness, set by the background provisioning
  // after create ("starting" → "ready" | "error"). Null for plain machines.
  runtimeStatus   String?
  // Soft-delete: when an owner "releases" a permanent machine we DON'T destroy
  // it — we stop billing + suspend (snapshot, data intact) and set status
  // "pending_deletion" + deletionScheduledAt=now. Fully restorable for 7 days;
  // a cron hard-destroys after the grace window. Null = not scheduled.
  deletionScheduledAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerId])
}

// Tracks an EPHEMERAL livekit-svc call box for the idle reaper (reapIdleStudios).
// These boxes are pure sandboxes (no Agent/Sandbox row) that the host auto-kills
// at TTL (3h). This row is the only place easybits remembers them, so the 60s
// reaper can poll each box's call status and apply the smart idle policy:
//   - everHadCall=false → 30 min idle-since-boot grace (waiting for a first call)
//   - active call (participants>0 or recording) → lastActiveAt refreshed (timer
//     suspended for the whole call)
//   - everHadCall=true and idle → 5 min grace, then destroyCall
// Created in spawnStudio, deleted in destroyCall (and by the reaper on cleanup).
model StudioBox {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId      String   @db.ObjectId
  sandboxId    String   @unique // host VM id — the box handle
  lastActiveAt DateTime @default(now()) // last tick we saw an active call (or boot)
  everHadCall  Boolean  @default(false) // flips true on first participant → 5min grace
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerId])
}

// On-demand fleet service box (template-backed microVM that provides a capability
// to a FleetAgent — e.g. voice = whisper STT + kokoro TTS). One row per
// (owner, kind) so ensureServiceBox is idempotent and never double-spawns. The
// idle reaper (reapIdleServiceBoxes) destroys boxes whose lastActiveAt crossed
// the idle grace. Mirrors StudioBox but generic over `kind`.
model ServiceBox {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId      String   @db.ObjectId
  kind         String // service kind (e.g. "voice"), key into SERVICE_REGISTRY
  sandboxId    String   @unique // host VM id — the box handle
  lastActiveAt DateTime @default(now()) // last STT/TTS use (or boot); idle clock
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ownerId, kind])
  @@index([ownerId])
}

// Reserved fleet capacity bought from /dash/packs (Sandboxes tab). Each ACTIVE
// row raises the owner's elastic-fleet budget: +1 machine slot and +`agents`
// agent slots (see pools.tsx capacity HUD). Created by the Stripe webhook on
// `checkout.session.completed` (type=reserved_sandbox); flipped to "cancelled"
// when its dedicated subscription is deleted. NOT a host VM — it's a capacity
// grant the fleet agent consumes on demand (distinct from the standalone permanent
// machines in the Sandbox model / /dash/hosting).
model SandboxReservation {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId              String   @db.ObjectId
  tier                 String   // catalog key: "nano".."performance-4x"
  agents               Int      // agent slots this reservation grants
  stripeSubscriptionId String   @unique // the dedicated monthly subscription
  status               String   @default("active") // active | cancelled
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([ownerId])
}
