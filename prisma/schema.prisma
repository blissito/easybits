generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum AiProvider {
  ANTHROPIC
  OPENAI
}

enum AssetType {
  VOD_COURSE
  EMAIL_COURSE
  WEBINAR
  EBOOK
  DOWNLOADABLE
}

type AssetExtraSettings {
  stock             String?
  showSold          Boolean?
  showReviews       Boolean?
  showInMarketplace Boolean?
}

type AssetTemplateSettings {
  ctaText      String
  templateName String
  host         String?
  slug         String?
}

type AssetWebinarMetadata {
  numberOfSessions String?
  roomId           String?
  freePages        String?
  numberOfPages    String?
}

model Asset {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  slug  String @unique
  title String

  actions       Json[]
  tags          String                 @default("")
  note          String?
  description   String?
  eventDate     DateTime?
  roomId        String? // provisional
  metadata      AssetWebinarMetadata? // used for type webinar, for example.
  type          AssetType              @default(DOWNLOADABLE)
  price         Float?                 @default(0)
  currency      String                 @default("mxn")
  gallery       String[]
  template      AssetTemplateSettings?
  published     Boolean                @default(false)
  publicLink    String?
  stripePrice   String?
  stripeProduct String?
  extra         AssetExtraSettings?
  // ownership and metadata
  userId        String                 @db.ObjectId
  user          User                   @relation(fields: [userId], references: [id])
  files         File[]
  // dates
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  Order         Order[]
  Review        Review[]
  book          Book?

  @@index([userId])
}

model Order {
  // must
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  customer_email String
  // Kind of sale: "asset_sale" | "credit_pack" | "subscription" | "custom".
  // Marketplace readers filter by assetId/merchantId, so platform orders
  // (assetId/merchantId null) are excluded from those views automatically.
  type           String?     @default("asset_sale")
  // Open line items — may or may not reference a model (asset/pack/plan).
  items          OrderItem[]
  // optional — only asset_sale orders carry an assetId/merchantId
  assetId        String?     @db.ObjectId
  price          Float?      @default(0)
  currency       String?     @default("mxn")
  status         String?     @default("Paid")
  merchantId     String?     @db.ObjectId // User.id
  customerId     String?     @db.ObjectId // Could also be User.id
  total          String?     @default("$ 0.00") // `$ 1024.50 MXN`
  priceId        String?
  productId      String?
  note           String?
  //
  merchant       User?       @relation("OrderMerchant", fields: [merchantId], references: [id])
  customer       User?       @relation("OrderCustomer", fields: [customerId], references: [id])
  asset          Asset?      @relation(fields: [assetId], references: [id])
  // dates
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([merchantId])
  @@index([customerId])
  @@index([assetId])
}

type OrderItem {
  kind      String // "asset" | "credit_pack" | "subscription" | "custom"
  refId     String? // assetId / packId / planKey — optional, open
  label     String
  quantity  Int     @default(1)
  unitPrice Float   @default(0)
}

type NewsLetter {
  next    Int    @default(1) // 0 is done
  assetId String
}

type Metadata {
  asset_types   String[]
  customer_type String?
  plan          String?
}

type Notifications {
  sells      Boolean @default(true)
  reviews    Boolean @default(true)
  newsletter Boolean @default(true)
}

// Recarga automática de saldo (auto-topup). Al alcanzar el límite, re-compra
// `packId` off-session con la tarjeta guardada. Un solo intento, sin insistir:
// si falla, enabled=false hasta reactivación manual. El bucket (créditos vs
// tokens) se deriva de packId — no se guarda. `charging` es el lock atómico
// compare-and-set; `chargeEpoch` hace única la idempotency key por ciclo.
type AutoTopup {
  enabled       Boolean   @default(false)
  packId        String
  paymentMethod String?
  charging      Boolean   @default(false)
  chargeEpoch   Int       @default(0)
  lastTopupAt   DateTime?
  failedAt      DateTime?
  lastError     String?
}

type StoreConfig {
  metadata                  Json?
  colorMode                 String  @default("light")
  typography                String  @default("")
  hexColor                  String  @default("")
  socialNetworks            Boolean @default(true)
  showProducts              Boolean @default(true)
  instagram                 String  @default("")
  facebook                  String  @default("")
  tiktok                    String  @default("")
  youtube                   String  @default("")
  linkedin                  String  @default("")
  website                   String  @default("")
  logoImage                 String  @default("")
  coverImage                String  @default("")
  googleAnalyticsTrackingId String  @default("")
  x                         String  @default("") // ? what for, remove?
}

model User {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  confirmed      Boolean        @default(false)
  trained        Boolean        @default(false)
  // file ownership
  // assets         Asset[]
  // storageUsed    Int?         @default(0) // thinking about it @todo
  assets         Asset[]
  files          File[]
  shareTokens    ShareToken[]
  publicKey      String?        @unique
  // defaults
  displayName    String?
  email          String         @unique
  verified_email Boolean?
  family_name    String?
  given_name     String?
  picture        String?
  phoneNumber    String?
  roles          String[]
  metadata       Metadata?
  stripeId       String?
  stripeIds      String[] // new. To work in dev and prod with confidence
  // domain stuff
  host           String?        @unique
  dnsConfig      Json?
  domain         String?
  // subscriptions
  newsletters    NewsLetter[]
  notifications  Notifications?
  assetIds       String[] // experiment
  customer       String?
  // dates
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  storeConfig    StoreConfig?
  Review           Review[]
  merchantOrders   Order[]          @relation("OrderMerchant")
  customerOrders   Order[]          @relation("OrderCustomer")
  apiKeys          ApiKey[]
  permissions      Permission[]     @relation("PermissionGrantee")
  grantedPermissions Permission[]   @relation("PermissionGranter")
  storageProviders StorageProvider[]
  aiKeys           UserAiKey[]
  websites         Website[]
  webhooks         Webhook[]
  databases        Database[]
  presentations      Presentation[]
  presentationStyles PresentationStyle[]
  landings           Landing[]
  customDomains    CustomDomain[]
  referrals        Referral[]     @relation("Referrals")
  referredBy       Referral?      @relation("ReferredBy")
  aiGenerationLogs AiGenerationLog[]
  // AI generation limits
  aiGenerationsCount   Int?       @default(0)
  aiGenerationsResetAt DateTime?
  aiGenerationsBonus   Int?       @default(0)
  // LLM proxy token limits (GhostyCode — separados de créditos de documentos)
  llmTokensUsed        Int        @default(0)
  llmTokensResetAt     DateTime?
  llmTokensBonus       Int        @default(0)
  autoTopup            AutoTopup?
  brandKits            BrandKit[]
  formConfigs          FormConfig[]
  paymentProviders     PaymentProvider[]
  paymentLinks         PaymentLink[]
  contacts             Contact[]
  broadcasts           Broadcast[]
  mcpTemplates         McpTemplate[]
  mcpStructuredDocs    McpStructuredDoc[]
  oauthAuthCodes       OAuthAuthCode[]
  characters           Character[]
  videoGenerations     VideoGeneration[]
  shareLinks           ShareLink[]
  secrets              Secret[]
  agents               Agent[]
  computeKeys          ComputeKey[]
  sandboxes            Sandbox[]
  fleetAgents          FleetAgent[]
}

model Secret {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  value      String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@unique([userId, name])
  @@index([userId])
}

model OAuthClient {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId          String   @unique
  clientSecretHash  String
  clientName        String
  redirectUris      String[]
  createdAt         DateTime @default(now())
  authCodes         OAuthAuthCode[]
}

model OAuthAuthCode {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  codeHash            String   @unique
  clientId            String
  client              OAuthClient @relation(fields: [clientId], references: [clientId])
  userId              String   @db.ObjectId
  user                User     @relation(fields: [userId], references: [id])
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String
  scope               String?
  expiresAt           DateTime
  used                Boolean  @default(false)
  createdAt           DateTime @default(now())
}

model OAuthRefreshToken {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash   String   @unique
  clientId    String
  userId      String   @db.ObjectId
  scope       String?
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

enum FileStatus {
  PENDING
  WORKING
  DONE
  ERROR
  DELETED
}

enum ApiKeyScope {
  READ
  WRITE
  DELETE
  ADMIN
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum StorageProviderType {
  TIGRIS
  CLOUDFLARE_R2
  AWS_S3
}

enum StorageRegion {
  LATAM
  US
  EU
}

model File {
  id                    String     @id @default(auto()) @map("_id") @db.ObjectId
  storageKey            String     @unique // this
  slug                  String     @unique // !
  name                  String // !
  size                  Float // !
  contentType           String // !
  metadata              Json?
  // ^ meta
  status                FileStatus @default(PENDING)
  masterPlaylistContent String?
  masterPlaylistURL     String?
  versions              String[]
  // ^ hls
  url                   String // ?
  access                String     @default("private")
  // ^ share
  ownerId               String     @db.ObjectId // this
  // ^ ownership
  owner                 User       @relation(fields: [ownerId], references: [id])
  assetIds              String[]   @db.ObjectId // this
  actionId              String?
  // ^ relations
  createdAt             DateTime   @default(now())
  source                String?
  deletedAt             DateTime?
  updatedAt             DateTime   @updatedAt
  // ^ auto-dates
  Asset                 Asset?     @relation(fields: [assetId], references: [id])
  assetId               String?    @db.ObjectId // deprecate!
  storageProviderId     String?    @db.ObjectId
  shareTokens           ShareToken[]

  @@index([ownerId])
  @@index([status])
  @@index([ownerId, status])
  @@index([deletedAt])
}

/// Template for structured_doc MCP tool. Stored as JSON-DSL (not code) — a tree
/// of {type, style, children, content, each, if} nodes that the renderer maps
/// to @react-pdf/renderer components. Templates are owned by a user; `isPublic`
/// templates are visible to all users via list_templates.
model McpTemplate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  /// JSON-DSL tree { type: "Document", pages: [...] }
  tree        Json
  /// JSON Schema describing the shape of `data` expected by this template
  dataSchema  Json
  ownerId     String   @db.ObjectId
  owner       User     @relation(fields: [ownerId], references: [id])
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   McpStructuredDoc[]

  @@index([ownerId])
  @@index([isPublic])
}

/// Document instance created from a McpTemplate. Stores only `data` (JSON) —
/// the LLM reads/writes just this JSON, never the rendered PDF/HTML.
model McpStructuredDoc {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  templateId String      @db.ObjectId
  template   McpTemplate @relation(fields: [templateId], references: [id])
  data       Json
  ownerId    String      @db.ObjectId
  owner      User        @relation(fields: [ownerId], references: [id])
  /// Cached last-rendered PDF fileId (via existing File model) — optional.
  lastPdfFileId String?  @db.ObjectId
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([ownerId])
  @@index([templateId])
}

model Client {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  userId      String @db.ObjectId
  email       String
  displayName String

  phone       String?
  address     String?
  companyName String?
  comments    String?
  assets      String[] @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // ^ auto-dates

  @@index([userId])
}

model Review {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @db.ObjectId
  user    User   @relation(fields: [userId], references: [id])
  assetId String @db.ObjectId
  Asset   Asset  @relation(fields: [assetId], references: [id])
  comment String
  rating  Int    @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
}

model ApiKey {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  hashedKey String       @unique
  prefix    String
  scopes    ApiKeyScope[]
  status    ApiKeyStatus @default(ACTIVE)
  expiresAt DateTime?
  revokedAt DateTime?
  userId    String       @db.ObjectId
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
}

model Permission {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  granteeId    String   @db.ObjectId
  grantee      User     @relation("PermissionGrantee", fields: [granteeId], references: [id])
  grantedById  String   @db.ObjectId
  grantedBy    User     @relation("PermissionGranter", fields: [grantedById], references: [id])
  resourceType String
  resourceId   String   @db.ObjectId
  canRead      Boolean  @default(true)
  canWrite     Boolean  @default(false)
  canDelete    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Micro-IAM: account-level delegation. An owner (accountId) grants another
// account (granteeId) a set of scopes over their account. Today: "machines"
// (operate all the owner's permanent machines). Extensible: "files", "dbs".
// Scalar ObjectIds (no @relation) on purpose — keeps it standalone, no User
// model changes. Lookups by granteeId (what's shared with me) + accountId
// (who I shared with). See app/.server/iam.ts (`can`/grant/revoke/list).
model Delegation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  accountId   String   @db.ObjectId
  granteeId   String   @db.ObjectId
  grantedById String   @db.ObjectId // who created the grant (audit)
  scopes      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([granteeId])
  @@index([accountId])
}

model StorageProvider {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  type      StorageProviderType
  region    StorageRegion
  isDefault Boolean             @default(false)
  config    Json
  userId    String              @db.ObjectId
  user      User                @relation(fields: [userId], references: [id])
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model UserAiKey {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  provider  AiProvider
  keyValue  String
  userId    String     @db.ObjectId
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, provider])
}

// ─── Funnel: pagos (MercadoPago BYO) + email/broadcasts ────────────────────────

enum PaymentProviderType {
  MERCADOPAGO
}

/// BYO credentials del usuario para su propia pasarela (espejo de UserAiKey).
/// v1: solo MercadoPago. accessToken se guarda enmascarado al devolverse.
model PaymentProvider {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  provider      PaymentProviderType @default(MERCADOPAGO)
  accessToken   String
  publicKey     String?
  webhookSecret String?
  isDefault     Boolean             @default(true)
  userId        String              @db.ObjectId
  user          User                @relation(fields: [userId], references: [id])
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([userId, provider])
}

/// Link de pago one-time creado vía Checkout Pro (preference → init_point).
model PaymentLink {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @db.ObjectId
  user              User      @relation(fields: [userId], references: [id])
  title             String
  amountCents       Int
  currency          String    @default("MXN")
  mpPreferenceId    String?
  initPoint         String?
  externalReference String    @unique
  status            String    @default("pending") // pending | paid
  payerEmail        String?
  createdAt         DateTime  @default(now())
  paidAt            DateTime?

  @@index([userId])
  @@index([status])
}

/// Contacto/audiencia del usuario. `status` cubre suppression sin tabla aparte.
model Contact {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  email     String
  name      String?
  tags      String[] @default([])
  status    String   @default("subscribed") // subscribed | unsubscribed | bounced
  createdAt DateTime @default(now())

  @@unique([userId, email])
  @@index([userId, status])
}

/// Envío one-shot (newsletter) a una audiencia filtrada por tag.
model Broadcast {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id])
  subject     String
  html        String
  audienceTag String?
  status      String    @default("draft") // draft | sending | sent
  total       Int       @default(0)
  sent        Int       @default(0)
  failed      Int       @default(0)
  createdAt   DateTime  @default(now())
  sentAt      DateTime?

  @@index([userId])
}

model Website {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  slug           String
  ownerId        String        @db.ObjectId
  owner          User          @relation(fields: [ownerId], references: [id])
  status         String        @default("ACTIVE")
  prefix         String
  fileCount      Int           @default(0)
  totalSize      Float         @default(0)
  customDomainId String?       @db.ObjectId
  customDomain   CustomDomain? @relation(fields: [customDomainId], references: [id])
  subdomainEnabled Boolean     @default(false)
  /** Ad-hoc per-site metadata: ogImageUrl (cached screenshot), description, etc. */
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([ownerId, slug])
  @@index([ownerId])
}

model CustomDomain {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  domain    String    @unique
  ownerId   String    @db.ObjectId
  owner     User      @relation(fields: [ownerId], references: [id])
  verified  Boolean   @default(false)
  txtToken  String
  websites  Website[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([ownerId])
}

model ShareToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fileId    String   @db.ObjectId
  file      File     @relation(fields: [fileId], references: [id])
  ownerId   String   @db.ObjectId
  owner     User     @relation(fields: [ownerId], references: [id])
  source    String   // "ui" | "mcp" | "sdk"
  expiresAt DateTime
  expiresIn Int      // original seconds requested
  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([fileId])
  @@index([expiresAt])
}

model ShareLink {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  resourceType String    // "document" | "landing"
  resourceId   String    @db.ObjectId
  permission   String    // "view" | "edit" | "download"
  ownerId      String    @db.ObjectId
  owner        User      @relation(fields: [ownerId], references: [id])
  source       String    // "mcp" | "ui" | "sdk"
  allowedOrigins String[] @default([]) // embed: origins allowed to iframe this link (CSP frame-ancestors). Empty = not embeddable.
  expiresAt    DateTime
  revokedAt    DateTime?
  lastUsedAt   DateTime?
  useCount     Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([ownerId])
  @@index([resourceType, resourceId])
  @@index([expiresAt])
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  FAILED
}

model Webhook {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  url       String
  events    String[]
  secret    String
  status    WebhookStatus @default(ACTIVE)
  failCount Int           @default(0)
  lastError String?
  userId    String        @db.ObjectId
  user      User          @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model Database {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  namespace   String   @unique
  description String?
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Presentation {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  prompt       String
  slides       Json     // { id, html, order }[]
  theme        String   @default("black")
  paletteId    String?  // reference to PRESENTATION_PALETTES
  transition   String   @default("slide") // reveal.js transition: slide, fade, convex, concave, zoom, none
  customColors Json?    // color overrides (future)
  status       String   @default("DRAFT") // DRAFT | PUBLISHED
  ownerId      String   @db.ObjectId
  owner        User     @relation(fields: [ownerId], references: [id])
  websiteId    String?  @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerId])
}

model PresentationStyle {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  designSystem  Json     // { colors, typography, spacing, layouts, decorativeElements, mood }
  sampleImages  Json?    // [base64 thumbnails of 3-4 key pages]
  sourceFileId  String?  @db.ObjectId // original PDF file reference
  ownerId       String   @db.ObjectId
  owner         User     @relation(fields: [ownerId], references: [id])
  createdAt     DateTime @default(now())

  @@index([ownerId])
}

model Landing {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  prompt    String
  sections  Json     // LandingSection[]
  theme        String   @default("modern")
  customColors Json?    // { bg, accent, text } hex colors
  metadata         Json?    // { theme, ... } extensible metadata
  sectionVersions  Json?    // Record<sectionId, {html, timestamp}[]>
  previousSections Json?    // Snapshot of sections before last update (undo)
  version          Int      @default(1)
  status       String   @default("DRAFT") // DRAFT | PUBLISHED
  ownerId   String   @db.ObjectId
  owner     User     @relation(fields: [ownerId], references: [id])
  websiteId String?  @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Referral {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  referrerId   String   @db.ObjectId
  referrer     User     @relation("Referrals", fields: [referrerId], references: [id])
  referredId   String   @db.ObjectId
  referred     User     @relation("ReferredBy", fields: [referredId], references: [id])
  status       String   @default("SIGNED_UP") // SIGNED_UP | UPGRADED
  bonusAwarded Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([referredId])
  @@index([referrerId])
}

model AiGenerationLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  type         String   // ServiceId from app/.server/services/registry.ts (e.g. "doc.gemini.generate", "video.hedra.avatar")
  product      String   // ServiceProduct: "doc" | "video" | "voice" | "image" | "avatar" | legacy values
  cost         Int      @default(1) // tokens (fichas) consumed by this operation. Doc=1, avatar 30s=15, etc.
  modelId      String?  // "gemini-2.5-pro", "claude-sonnet-4-6"
  inputTokens  Int?
  outputTokens Int?
  resourceId   String?  // landingId of the document/landing
  pageCount    Int?     // pages generated
  durationMs   Int?     // total generation time
  source       String?  // "monthly" | "bonus" | "split" — which quota bucket was consumed
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, product])
  @@index([createdAt])
}

